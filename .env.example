# ---------------------------------------------------------------------------
# Yeshwa Modular Furniture — environment variables
# Copy to `.env` (local) and configure in Cloudflare Pages for production.
# Never commit real secrets. VITE_* vars are exposed to the browser bundle.
# ---------------------------------------------------------------------------

# --- Public (browser) — safe to expose ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Public site config (optional overrides; have sensible defaults in code)
VITE_SITE_URL=https://yeshwa.studio
VITE_WHATSAPP_NUMBER=

# --- Server-only (Cloudflare Pages Functions) — NEVER prefix with VITE_ ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare R2 (media storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=

# Optional enquiry-notification webhook (Make.com or n8n)
MAKE_OR_N8N_WEBHOOK_URL=
